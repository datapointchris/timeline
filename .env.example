# Server runtime configuration. Copy to .env (gitignored) for local overrides,
# or set on the host (e.g. /etc/timeline/.env on timeline-lxc) for production.

# HTTP listener
PORT=3000

# Application mode. "production" enables JSON logs and SPA static serving.
NODE_ENV=production

# SQLite database file path. In dev defaults to ../data/timeline.db relative to
# server/src/db. In the production image, /app/data is the bind-mounted volume.
DATABASE_PATH=/app/data/timeline.db

# Where Drizzle finds the migration SQL files. In the image these live at
# /app/migrations (top-level). In dev they live at server/migrations.
MIGRATIONS_FOLDER=/app/migrations

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional: where the production server reads the SPA static bundle from.
# Defaults to ../client-dist relative to dist/index.js. The Docker runtime
# image already places client/dist there.
# STATIC_DIR=/app/client-dist
